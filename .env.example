# ============================================================
# uVoice Navigator API - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# ============================================================

# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/uvoice_navigator?schema=public"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=uVoice Navigator
SMTP_FROM_EMAIL=noreply@uvoicenavigator.com

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
THROTTLE_AUTH_LIMIT=5

# Wasabi / S3 Storage
WASABI_ACCESS_KEY=your-wasabi-access-key
WASABI_SECRET_KEY=your-wasabi-secret-key
WASABI_BUCKET=uvoice-audio-files
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.wasabisys.com

# Logging
LOG_LEVEL=debug
LOG_DIR=logs

# Bcrypt
BCRYPT_ROUNDS=12

# Cache TTL (seconds)
CACHE_TTL=3600
DASHBOARD_CACHE_TTL=300

# ── SQL SERVER (BCB Go Contact) ──────────────────────────────
MSSQL_HOST=10.11.1.31
MSSQL_PORT=1433
MSSQL_USER=usr_audioETL
MSSQL_PASS=P@$s_4ud1Oe.te.ele
MSSQL_DATABASE=DBC
