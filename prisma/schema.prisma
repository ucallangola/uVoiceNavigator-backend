// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Auth & RBAC Models
// ============================================================

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  refreshToken String?   @map("refresh_token")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  roles          UserRole[]
  auditLogs      AuditLog[]
  audioAccessLogs AudioAccessLog[]
  notifications  Notification[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(uuid())
  name      String   @unique
  resource  String
  action    String
  createdAt DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================
// Business Models
// ============================================================

model Interaction {
  id                  String   @id @default(uuid())
  recordType          String   @map("record_type") // 'inbound' | 'outbound'
  callId              String   @map("call_id")
  date                DateTime
  agentName           String   @map("agent_name")
  agentId             String   @map("agent_id")
  campaign            String
  campaignType        String   @map("campaign_type")
  skill               String
  customerName        String   @map("customer_name")
  customerEmail       String   @map("customer_email")
  customerPhone       String   @map("customer_phone")
  ani                 String
  dnis                String
  segment             String
  list                String
  contactId           String   @map("contact_id")
  talkTime            Int      @map("talk_time") // seconds
  handleTime          Int      @map("handle_time")
  holdTime            Int      @map("hold_time")
  ivrTime             Int      @map("ivr_time")
  waitTime            Int      @map("wait_time")
  wrapTime            Int      @map("wrap_time")
  disposition         String
  dispositionGroupA   String   @map("disposition_group_a")
  dispositionGroupB   String   @map("disposition_group_b")
  dispositionGroupC   String   @map("disposition_group_c")
  dialResult          String   @map("dial_result")
  abandoned           Boolean  @default(false)
  callCount           Int      @default(0) @map("call_count")
  suspensionCount     Int      @default(0) @map("suspension_count")
  ivrContact          String   @map("ivr_contact")
  ivrNif              String   @map("ivr_nif")
  ivrAccountNumber    String   @map("ivr_account_number")
  businessMonth       Int      @map("business_month")
  businessDayOfWeek   Int      @map("business_day_of_week")
  businessDayOfMonth  Int      @map("business_day_of_month")
  businessHour        Int      @map("business_hour")
  evaluated           Boolean  @default(false)
  status              String   @default("pending") // 'processed' | 'pending' | 'error'
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([date])
  @@index([agentId])
  @@index([campaign])
  @@index([recordType])
  @@index([status])
  @@index([customerPhone])
  @@map("interactions")
}

model Audio {
  id            String    @id @default(uuid())
  filename      String
  source        String    // 'GO_CONTACT' | 'FIVE9'
  agentName     String    @map("agent_name")
  customerPhone String    @default("") @map("customer_phone")
  callId        String?   @map("call_id")  // extracted from filename: {recordingId}_{callId}_{...}
  duration      Int       // seconds
  processedAt   DateTime? @map("processed_at")
  uploadedAt    DateTime  @default(now()) @map("uploaded_at")
  wasabiUrl     String    @map("wasabi_url")
  status        String    @default("pending") // 'processed' | 'pending' | 'error'
  fileSize      Int       @map("file_size") // bytes
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accessLogs        AudioAccessLog[]
  audioInteractions AudioInteraction[]

  @@index([status])
  @@index([source])
  @@index([agentName])
  @@index([uploadedAt])
  @@index([callId])
  @@map("audios")
}

// Links audio files to call records (by phone number — no FK since Interactions live in SQL Server)
model AudioInteraction {
  id            String   @id @default(uuid())
  audioId       String   @map("audio_id")
  customerPhone String   @map("customer_phone")
  callId        String   @map("call_id")     // SQL Server call ID
  matchedAt     DateTime @default(now()) @map("matched_at")

  audio Audio @relation(fields: [audioId], references: [id], onDelete: Cascade)

  @@unique([audioId, callId])
  @@index([audioId])
  @@index([customerPhone])
  @@map("audio_interactions")
}

model AudioAccessLog {
  id        String   @id @default(uuid())
  audioId   String   @map("audio_id")
  userId    String?  @map("user_id")  // nullable — anonymous/system access allowed
  action    String   // 'play' | 'download'
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  audio Audio  @relation(fields: [audioId], references: [id], onDelete: Cascade)
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([audioId])
  @@index([userId])
  @@index([createdAt])
  @@map("audio_access_logs")
}

model EmailAlert {
  id             String    @id @default(uuid())
  recipientEmail String    @map("recipient_email")
  alertType      String    @default("instant") @map("alert_type") // 'instant' | 'scheduled'
  sendHour       Int?      @map("send_hour") // 0-23, used only for 'scheduled' type
  enabled        Boolean   @default(true)
  lastSent       DateTime? @map("last_sent")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("email_alerts")
}

// ============================================================
// ETL Models
// ============================================================

model EtlRun {
  id          String    @id @default(uuid())
  startedAt   DateTime  @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  status      String    @default("running") // 'running' | 'completed' | 'failed'
  totalFiles  Int       @default(0) @map("total_files")
  uploaded    Int       @default(0)
  failed      Int       @default(0)
  skipped     Int       @default(0)
  retried     Int       @default(0)
  errorMsg    String?   @map("error_msg")

  files EtlFile[]
  logs  EtlLog[]

  @@index([startedAt])
  @@index([status])
  @@map("etl_runs")
}

model EtlFile {
  id           String    @id @default(uuid())
  runId        String    @map("run_id")
  filename     String
  sourcePath   String    @map("source_path")
  wasabiKey    String?   @map("wasabi_key")
  wasabiUrl    String?   @map("wasabi_url")
  fileSize     Int       @map("file_size")
  mimeType     String?   @map("mime_type")
  status       String    @default("pending") // 'pending' | 'uploaded' | 'moved' | 'failed'
  errorMsg     String?   @map("error_msg")
  attemptCount Int       @default(0) @map("attempt_count")
  processedAt  DateTime? @map("processed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  run EtlRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([status])
  @@index([filename])
  @@map("etl_files")
}

model EtlLog {
  id        String   @id @default(uuid())
  runId     String   @map("run_id")
  level     String   @default("info") // 'info' | 'warn' | 'error'
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  run EtlRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([createdAt])
  @@map("etl_logs")
}

// Dynamic ETL schedule stored in DB (one active row)
model EtlSchedule {
  id             String   @id @default(uuid())
  enabled        Boolean  @default(false)
  cronExpression String   @map("cron_expression")
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("etl_schedules")
}

// Persistent in-app notifications
model Notification {
  id           String    @id @default(uuid())
  userId       String?   @map("user_id") // null = broadcast (visible to all)
  type         String    // 'etl:completed' | 'etl:failed' | 'etl:file:failed' | etc.
  title        String
  message      String
  read         Boolean   @default(false)
  resourceType String?   @map("resource_type") // 'etl_run' | 'audio'
  resourceId   String?   @map("resource_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================================
// Audit
// ============================================================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}
